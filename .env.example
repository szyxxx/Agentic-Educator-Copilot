# Educator Copilot — Environment Variables
# Copy this file to .env and fill in your API keys

# LLM API Keys (at least one required)
OPENROUTER_API_KEY=sk-or-v1-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# LLM Models Configuration
LLM_HEAVY_MODEL=anthropic/claude-3.5-sonnet
LLM_LIGHT_MODEL=anthropic/claude-3-haiku

# Force local LLM via Ollama (set to "true" for offline mode)
FORCE_LOCAL_LLM=true

# Database path (default: educator_copilot.db in project root)
DB_PATH=educator_copilot.db
