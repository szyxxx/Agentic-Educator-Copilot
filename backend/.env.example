# Copy this file to `.env` next to it and fill in the values you have.
# `app/core/config.py` auto-loads `.env` on backend startup.

# --- Database -------------------------------------------------------------
# DATABASE_URL=sqlite:///./educopilot.db
# ENVIRONMENT=development

# --- LLM provider routing -------------------------------------------------
# Comma-separated list. The first provider with valid credentials wins.
# Default: openrouter,anthropic,ollama
# LLM_PROVIDER_ORDER=openrouter,anthropic,ollama

# --- OpenRouter (PRIMARY) -------------------------------------------------
OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL_COMPLEX=anthropic/claude-sonnet-4.5
# OPENROUTER_MODEL_SIMPLE=anthropic/claude-haiku-4.5
# OPENROUTER_REFERER=http://localhost:3000
# OPENROUTER_TITLE=EduCopilot

# --- Anthropic native (FALLBACK when OpenRouter is unavailable) -----------
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL_COMPLEX=claude-sonnet-4-5
# ANTHROPIC_MODEL_SIMPLE=claude-haiku-4-5

# --- Local Ollama (last resort) -------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=gemma3:4b
